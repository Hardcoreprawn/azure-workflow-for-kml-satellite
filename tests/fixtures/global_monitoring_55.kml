<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Global Monitoring Portfolio</name>
    <description>55 realistic polygons across 8 regions — conservation, EUDR compliance, agriculture, and rangeland monitoring</description>

    <!-- ============================================================ -->
    <!-- Region 1: Amazon Deforestation Frontier — Rondônia, Brazil    -->
    <!-- Elongated clearings along feeder roads off BR-364             -->
