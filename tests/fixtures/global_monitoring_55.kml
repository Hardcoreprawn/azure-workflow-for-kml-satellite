    <Folder>
      <name>Amazon Deforestation Frontier</name>
      <description>Rondônia, Brazil — cleared parcels along the deforestation arc</description>

      <Placemark>
        <name>AMZ-01 Clearing Alpha</name>
        <description>Rectangular clearing along N-S feeder road, ~25 ha</description>
