<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Polygon With Hole</name>
    <Placemark>
      <name>Ring Block</name>
      <description>Outer polygon with an inner hole (e.g. pond or building)</description>
      <Polygon>
        <outerBoundaryIs>
          <LinearRing>
            <coordinates>
              36.80,-1.30,0
              36.82,-1.30,0
              36.82,-1.32,0
              36.80,-1.32,0
              36.80,-1.30,0
            </coordinates>
          </LinearRing>
        </outerBoundaryIs>
        <innerBoundaryIs>
          <LinearRing>
            <coordinates>
              36.805,-1.305,0
              36.815,-1.305,0
              36.815,-1.315,0
              36.805,-1.315,0
              36.805,-1.305,0
            </coordinates>
          </LinearRing>
        </innerBoundaryIs>
      </Polygon>
    </Placemark>
  </Document>
</kml>
